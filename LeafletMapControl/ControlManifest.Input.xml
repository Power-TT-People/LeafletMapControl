<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="LHRIC" constructor="LeafletMapControl" version="0.0.1" display-name-key="LeafletMapControl" description-key="LeafletMapControl description" control-type="standard" >
    <!--external-service-usage node declares whether this 3rd party PCF control is using external service or not, if yes, this control will be considered as premium and please also add the external domain it is using.
    If it is not using any external service, please set the enabled="false" and DO NOT add any domain below. The "enabled" will be false by default.
    Example1:
      <external-service-usage enabled="true">
        <domain>www.Microsoft.com</domain>
      </external-service-usage>
    Example2:
      <external-service-usage enabled="false">
      </external-service-usage>
    -->
    <external-service-usage enabled="true">
      <domain>unpkg.com</domain>
      <domain>tile.openstreetmap.org</domain>
      <domain>nominatim.openstreetmap.org</domain>
    </external-service-usage>
    <property name="defaultLatitude" display-name-key="Default Latitude" description-key="Default map center latitude" of-type="Decimal" usage="input" required="false" />
    <property name="defaultLongitude" display-name-key="Default Longitude" description-key="Default map center longitude" of-type="Decimal" usage="input" required="false" />
    <property name="defaultZoom" display-name-key="Default Zoom" description-key="Default map zoom level" of-type="Whole.None" usage="input" required="false" />

    <!-- Field mapping: set these to the logical names of columns in your view -->
    <property name="latitudeField" display-name-key="Latitude Field" description-key="Logical name of the latitude column (e.g. address1_latitude)" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="longitudeField" display-name-key="Longitude Field" description-key="Logical name of the longitude column (e.g. address1_longitude)" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="titleField" display-name-key="Title Field" description-key="Logical name of the column to use as the marker title (e.g. name, fullname, subject)" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="descriptionField" display-name-key="Description Field" description-key="Logical name of the column to use as the popup description (e.g. description, emailaddress1)" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="addressLine1Field" display-name-key="Address Line 1 Field" description-key="Logical name of the street address line 1 column for geocoding fallback (e.g. address1_line1)" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="addressCityField" display-name-key="City Field" description-key="Logical name of the city column for geocoding fallback (e.g. address1_city)" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="addressStateField" display-name-key="State/Province Field" description-key="Logical name of the state/province column for geocoding fallback (e.g. address1_stateorprovince)" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="addressPostalCodeField" display-name-key="Postal Code Field" description-key="Logical name of the postal code column for geocoding fallback (e.g. address1_postalcode)" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="addressCountryField" display-name-key="Country Field" description-key="Logical name of the country column for geocoding fallback (e.g. address1_country)" of-type="SingleLine.Text" usage="input" required="false" />

    <!-- dataset node represents a set of entity records on CDS; allow more than one datasets -->
    <data-set name="mapDataSet" display-name-key="Dataset_Display_Key">
      <!-- 'property-set' node represents a unique, configurable property that each record in the dataset must provide. -->
      <!-- UNCOMMENT TO ADD PROPERTY-SET NODE
      <property-set name="samplePropertySet" display-name-key="Property_Display_Key" description-key="Property_Desc_Key" of-type="SingleLine.Text" usage="bound" required="true" />
      -->
    </data-set>
    <resources>
      <code path="index.ts" order="1"/>
      <css path="css/LeafletMapControl.css" order="2" />
      <!-- UNCOMMENT TO ADD MORE RESOURCES
      <resx path="strings/LeafletMapControl.1033.resx" version="1.0.0" />
      -->
    </resources>
    <!-- UNCOMMENT TO ENABLE THE SPECIFIED API
    <feature-usage>
      <uses-feature name="Device.captureAudio" required="true" />
      <uses-feature name="Device.captureImage" required="true" />
      <uses-feature name="Device.captureVideo" required="true" />
      <uses-feature name="Device.getBarcodeValue" required="true" />
      <uses-feature name="Device.getCurrentPosition" required="true" />
      <uses-feature name="Device.pickFile" required="true" />
      <uses-feature name="Utility" required="true" />
      <uses-feature name="WebAPI" required="true" />
    </feature-usage>
    -->
  </control>
</manifest>
